@model Day05.ViewModels.StudentIndexVM

@{
    ViewData["Title"] = "Students List";
    Layout = "_StudentLayout";
}

<div class="card mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Students</h5>
        <a href="/Student/Add" class="btn btn-success"><i class="fas fa-plus me-1"></i> Add New Student</a>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Student" class="row g-3 mb-4">
            <div class="col-md-5">
                <input type="text" name="searchName" class="form-control" placeholder="Search by name..." value="@Model.SearchName" />
            </div>
            <div class="col-md-5">
                <select name="departmentId" class="form-select" asp-items="@(new SelectList(Model.Departments, "Id", "Name", Model.DepartmentId))">
                    <option value="">-- Filter by Department --</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i> Search</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Department</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Students)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.Age</td>
                            <td>@(item.Department?.Name ?? "N/A")</td>
                            <td class="text-center">
                                <a href="/Student/ShowDetails/@item.Id" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i></a>
                                <a href="/Student/Edit/@item.Id" class="btn btn-sm btn-warning text-white"><i class="fas fa-edit"></i></a>
                                <a href="/Student/Delete/@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Students.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No students found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="/Student/Index?page=@(Model.CurrentPage - 1)&searchName=@Model.SearchName&departmentId=@Model.DepartmentId">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Student/Index?page=@i&searchName=@Model.SearchName&departmentId=@Model.DepartmentId">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="/Student/Index?page=@(Model.CurrentPage + 1)&searchName=@Model.SearchName&departmentId=@Model.DepartmentId">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>