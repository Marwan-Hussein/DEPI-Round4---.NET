@model List<Student>


<table class="table table-hover table-bordered">
	<tr>
		<th>ID</th>
		<th>Name</th>
		<th>Age</th>
		<th>Department</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.Id </td>
			<td>@item.Name </td>
			<td>@item.Age </td>
			<td>@item.Department.Name </td>
		</tr>
    }

</table>