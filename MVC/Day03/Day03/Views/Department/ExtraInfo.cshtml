@using Day03.ViewModels;
@model List<DepartmentWithExtraInfoVM>
@{
    ViewData["Title"] = "Department Extra Info";
}

<table class="table table-hover table-bordered">
	<tr>
		<th>Department Name</th>
		<th>Students > 25</th>
		<th>State</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.DepName </td>
			<td>
				@foreach(var studentName in item.StudentsEx25Names)
				{
					<li>@studentName </li>
				}
			</td>
			<td>@item.State </td>
		</tr>
	}

</table>
