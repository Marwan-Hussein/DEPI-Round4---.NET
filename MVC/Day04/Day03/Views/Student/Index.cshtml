@model List<Student>

<form method="get" action="/Student/ShowDetails" class="d-flex gap-2 align-items-center">
	<input type="number" name="id" class="form-control" placeholder="Enter Student ID" min="1" required />
	<button type="submit" class="btn btn-secondary" style="width:max-content">Show Details</button>
</form>

<table class="table table-hover table-bordered">
	<tr>
		<th>ID</th>
		<th>Name</th>
		<th>Age</th>
		<th>Department</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.Id </td>
			<td>@item.Name </td>
			<td>@item.Age </td>
			<td>@item.Department.Name </td>
		</tr>
    }

</table>
<form method="get" action="/Student/Add" class="d-flex gap-2 align-items-center">
	<button class="btn btn-success">Add New</button>
</form>