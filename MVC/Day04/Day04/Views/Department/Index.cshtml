@model List<Department>

<form method="get" action="/Department/ShowDetails" class="d-flex gap-2 align-items-center">
	<input type="number" name="id" class="form-control" placeholder="Enter Department ID" min="1" required />
	<button type="submit" class="btn btn-secondary" style="width:max-content">Show Details</button>
</form>

<table class="table table-hover table-bordered">
	<tr>
		<th>ID</th>
		<th>Name</th>
		<th>Manager Name</th>

		<th># Teachers</th>
		<th># Courses</th>
		<th># Students</th>

	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.Id </td>
			<td>@item.Name </td>
			<td>@item.MgrName </td>

			<td>@item.Teachers?.Count() </td>
			<td>@item.Courses?.Count() </td>
			<td>@item.Students?.Count() </td>

		</tr>
	}

</table>

<form method="get" action="/Department/Add" class="d-flex gap-2 align-items-center">
	<button class="btn btn-success">Add New</button>
</form>
<a href="/Department/ExtraInfo"> for more info</a>

@*up/down arrows to navigate allover the page*@
<div id="scrollToBottom" title="Go to bottom" style="position: fixed; bottom: 30px; right: 30px; z-index: 99; cursor: pointer; background: linear-gradient(135deg, #6366f1, #a855f7); color: white; width: 56px; height: 56px; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4); display: flex; align-items: center; justify-content: center; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid rgba(255, 255, 255, 0.2); backdrop-filter: blur(8px);">
	<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
		<path d="M7 13l5 5 5-5M7 6l5 5 5-5" />
	</svg>
</div>

<div id="scrollToTop" title="Go to top" style="position: fixed; bottom: 100px; right: 30px; z-index: 99; cursor: pointer; background: linear-gradient(135deg, #6366f1, #a855f7); color: white; width: 56px; height: 56px; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4); display: flex; align-items: center; justify-content: center; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid rgba(255, 255, 255, 0.2); backdrop-filter: blur(8px);">
	<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
		<path d="M17 11l-5-5-5 5M17 18l-5-5-5 5" />
	</svg>
</div>

@section Scripts {
	<script>
		function setupScrollButton(id, targetTop) {
			const btn = document.getElementById(id);
			if (!btn) return;

			btn.addEventListener('mouseenter', () => {
				btn.style.transform = 'translateY(-5px) scale(1.05)';
				btn.style.boxShadow = '0 20px 25px -5px rgba(99, 102, 241, 0.5)';
			});

			btn.addEventListener('mouseleave', () => {
				btn.style.transform = 'translateY(0) scale(1)';
				btn.style.boxShadow = '0 10px 25px -5px rgba(99, 102, 241, 0.4)';
			});

			btn.addEventListener('click', () => {
				window.scrollTo({
					top: targetTop === 'bottom' ? document.documentElement.scrollHeight : 0,
					behavior: 'smooth'
				});
			});
		}

		setupScrollButton('scrollToBottom', 'bottom');
		setupScrollButton('scrollToTop', 'top');
	</script>
}